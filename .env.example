# ── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Database ──────────────────────────────────────────────────────────────────
# Local:
# DATABASE_URL="postgresql://postgres:Year22025@localhost:5432/smartrans_connect?schema=public"
#
# Vercel/Supabase runtime:
# Use the Supabase transaction pooler on port 6543 with a low Prisma connection limit.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Must be at least 32 characters — generate with: openssl rand -hex 32
JWT_SECRET=change_me_to_a_long_random_secret_at_least_32_chars
JWT_EXPIRES_IN=1d

# ── CORS (production) ─────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=https://smartransfrontend.vercel.app,https://smartransconnect.vercel.app

# ── Speed limit default ───────────────────────────────────────────────────────
DEFAULT_SPEED_LIMIT=80

# ── SMS — Nalo Solutions (https://nalosolutions.com) ──────────────────────────
ENABLE_SMS_NOTIFICATIONS=false
NALO_API_URL=https://api.nalosolutions.com/sms/v1/text/single
NALO_API_KEY=your_nalo_api_key_here
NALO_SENDER_ID=SmarTrans

# ── Email — SMTP ──────────────────────────────────────────────────────────────
ENABLE_EMAIL_NOTIFICATIONS=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_FROM=SmarTrans <noreply@smartrans.com>

# ── Push — Expo Push API ──────────────────────────────────────────────────────
ENABLE_PUSH_NOTIFICATIONS=false
EXPO_ACCESS_TOKEN=
